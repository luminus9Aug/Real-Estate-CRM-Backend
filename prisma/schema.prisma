generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm, pgcrypto]
}

// ═══════════════════════════════
// ENUMS
// ═══════════════════════════════
enum LeadStatus {
  HOT
  WARM
  COLD
  LOST
  CONVERTED
  HOLD
}

enum LeadSource {
  WHATSAPP
  WALKIN
  REFERENCE
  FACEBOOK
  GOOGLE
  NINETY_NINE_ACRES
  MAGICBRICKS
  HOUSING
  OTHER
}

enum PropertyType {
  PLOT
  APARTMENT
  COMMERCIAL
  VILLA
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  HELD
  BOOKED
}

enum UserRole {
  OWNER
  MANAGER
  AGENT
  VIEWER
  SUPER_ADMIN
}

enum ActivityType {
  CALL
  VISIT
  NOTE
  EMAIL
  WHATSAPP
  MEETING
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
  DISPUTED
}

enum CommissionType {
  PERCENT
  FIXED
}

enum SupportedLanguage {
  en
  hi
  ar
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum FeatureKey {
  MAX_AGENTS
  MAX_LEADS_PER_MONTH
  MAX_PROPERTIES
  WHATSAPP_INTEGRATION
  ADVANCED_REPORTS
  API_ACCESS
  CUSTOM_BRANDING
}

enum FeatureType {
  BOOLEAN      // enabled/disabled
  QUOTA        // numeric limit
  RATE_LIMITED // per-day/per-hour limit
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  VOID
  REFUNDED
}

// ═══════════════════════════════
// TENANT
// ═══════════════════════════════
model Tenant {
  id                 String            @id @default(cuid()) @map("id")
  name               String            @db.VarChar(200) @map("name")
  subdomain          String            @unique @db.VarChar(100) @map("subdomain")
  logoUrl            String?           @db.Text @map("logo_url")
  currency           String            @default("INR") @db.VarChar(3) @map("currency")
  timezone           String            @default("Asia/Kolkata") @db.VarChar(50) @map("timezone")
  phone              String?           @db.VarChar(20) @map("phone")
  email              String?           @db.VarChar(200) @map("email")
  address            String?           @db.Text @map("address")
  defaultLanguage    SupportedLanguage @default(en) @map("default_language")
  supportedLanguages SupportedLanguage[] @map("supported_languages")
  isActive           Boolean           @default(true) @map("is_active")
  
  // Subscription fields
  currentPlanId      String?           @map("current_plan_id")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndsAt        DateTime?         @map("trial_ends_at")
  
  // Data retention
  cancelledAt        DateTime?         @map("cancelled_at")
  dataRetentionUntil DateTime?         @map("data_retention_until")
  archivedAt         DateTime?         @map("archived_at")
  
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // Relations
  currentPlan            Plan?              @relation("TenantCurrentPlan", fields: [currentPlanId], references: [id])
  subscriptions          Subscription[]
  invoices               Invoice[]
  
  users                  User[]
  leads                  Lead[]
  properties             Property[]
  messages               Message[]
  activities             Activity[]
  followUps              FollowUp[]
  commissionTransactions CommissionTransaction[]
  brochureLinks          BrochureLink[]
  blogPosts              BlogPost[]

  @@index([subdomain])
  @@index([subscriptionStatus, trialEndsAt])
  @@index([archivedAt])
  @@map("tenants")
}

// ═══════════════════════════════
// PLAN
// ═══════════════════════════════
model Plan {
  id              String   @id @default(cuid()) @map("id")
  name            String   @db.VarChar(100) @map("name")
  version         Int      @default(1) @map("version")
  displayName     Json     @map("display_name")
  description     Json?    @map("description")
  // ── Pricing Rule Columns (admin-controlled) ──────────────────────────────
  // Admin sets basePriceMonthly (INR) + aedMultiplier + yearlyDiscountPct.
  // The backend service computes and persists all four currency columns below.
  basePriceMonthly  Decimal  @default(0) @db.Decimal(10,2) @map("base_price_monthly")
  aedMultiplier     Decimal  @default(0.05) @db.Decimal(10,6) @map("aed_multiplier")
  yearlyDiscountPct Decimal  @default(20) @db.Decimal(5,2) @map("yearly_discount_pct")

  // ── Computed Currency Columns (auto-populated by AdminService) ────────────
  priceMonthly    Decimal  @db.Decimal(10,2) @map("price_monthly")
  priceYearly     Decimal? @db.Decimal(10,2) @map("price_yearly")
  priceMonthlyINR Decimal  @default(0) @db.Decimal(10,2) @map("price_monthly_inr")
  priceYearlyINR  Decimal  @default(0) @db.Decimal(10,2) @map("price_yearly_inr")
  priceMonthlyAED Decimal  @default(0) @db.Decimal(10,2) @map("price_monthly_aed")
  priceYearlyAED  Decimal  @default(0) @db.Decimal(10,2) @map("price_yearly_aed")
  currency        String   @default("INR") @db.VarChar(3) @map("currency")
  trialDays       Int      @default(14) @map("trial_days")
  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")
  sortOrder       Int      @default(0) @map("sort_order")
  
  effectiveFrom   DateTime @default(now()) @map("effective_from")
  effectiveTo     DateTime? @map("effective_to")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  features        PlanFeature[]
  subscriptions   Subscription[]
  currentTenants  Tenant[]       @relation("TenantCurrentPlan")

  @@unique([name, version])
  @@index([isActive, sortOrder])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("plans")
}

// ═══════════════════════════════
// PLAN FEATURE
// ═══════════════════════════════
model PlanFeature {
  id          String      @id @default(cuid()) @map("id")
  planId      String      @map("plan_id")
  featureKey  String      @map("feature_key")
  type        FeatureType @default(BOOLEAN) @map("type")
  limit       Int?        @map("limit")
  config      Json?       @map("config")
  isEnabled   Boolean     @default(true) @map("is_enabled")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([planId, isEnabled])
  @@map("plan_features")
}

// ═══════════════════════════════
// SUBSCRIPTION
// ═══════════════════════════════
model Subscription {
  id                 String             @id @default(cuid()) @map("id")
  tenantId           String             @map("tenant_id")
  planId             String             @map("plan_id")
  planVersion        Int                @default(1) @map("plan_version")
  
  status             SubscriptionStatus @default(TRIAL) @map("status")
  interval           PlanInterval       @default(MONTHLY) @map("interval")
  
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  
  cancelledAt        DateTime?          @map("cancelled_at")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  
  trialStart         DateTime?          @map("trial_start")
  trialEnd           DateTime?          @map("trial_end")
  
  scheduledPlanId    String?            @map("scheduled_plan_id")
  scheduledChangeAt  DateTime?          @map("scheduled_change_at")
  
  unusedCredit       Decimal?           @db.Decimal(10,2) @map("unused_credit")
  lastPlanChangeAt   DateTime?          @map("last_plan_change_at")
  
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
  @@index([currentPeriodEnd])
  @@index([status, currentPeriodEnd])
  @@map("subscriptions")
}

// ═══════════════════════════════
// INVOICE
// ═══════════════════════════════
model Invoice {
  id              String        @id @default(cuid()) @map("id")
  tenantId        String        @map("tenant_id")
  invoiceNumber   String        @unique @map("invoice_number")
  
  status          InvoiceStatus @default(PENDING) @map("status")
  
  subtotal        Decimal       @db.Decimal(12,2) @map("subtotal")
  taxAmount       Decimal       @db.Decimal(12,2) @map("tax_amount")
  total           Decimal       @db.Decimal(12,2) @map("total")
  currency        String        @db.VarChar(3) @map("currency")
  
  taxRate         Decimal       @db.Decimal(5,2) @map("tax_rate")
  taxType         String        @db.VarChar(20) @map("tax_type")
  taxId           String?       @db.VarChar(50) @map("tax_id")
  
  issuedAt        DateTime      @map("issued_at")
  dueAt           DateTime      @map("due_at")
  paidAt          DateTime?     @map("paid_at")
  voidedAt        DateTime?     @map("voided_at")
  
  pdfUrl          String?       @db.Text @map("pdf_url")
  
  paymentId       String?       @map("payment_id")
  paymentMethod   String?       @db.VarChar(50) @map("payment_method")
  
  lineItems       Json          @map("line_items")
  metadata        Json?         @map("metadata")
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, issuedAt])
  @@index([status, dueAt])
  @@index([paymentId])
  @@map("invoices")
}

// ═══════════════════════════════
// WEBHOOK EVENT
// ═══════════════════════════════
model WebhookEvent {
  id            String    @id @default(cuid()) @map("id")
  provider      String    @db.VarChar(50) @map("provider")
  eventId       String    @unique @map("event_id")
  eventType     String    @db.VarChar(100) @map("event_type")
  processed     Boolean   @default(false) @map("processed")
  processedAt   DateTime? @map("processed_at")
  retryCount    Int       @default(0) @map("retry_count")
  lastError     String?   @db.Text @map("last_error")
  payload       Json      @map("payload")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([processed, retryCount])
  @@index([createdAt])
  @@map("webhook_events")
}

// ═══════════════════════════════
// AUDIT LOG
// ═══════════════════════════════
model AuditLog {
  id          String    @id @default(cuid()) @map("id")
  tenantId    String?   @map("tenant_id")
  userId      String?   @map("user_id")
  action      String    @db.VarChar(100) @map("action")
  entity      String    @db.VarChar(50) @map("entity")
  entityId    String    @map("entity_id")
  before      Json?     @map("before")
  after       Json?     @map("after")
  metadata    Json?     @map("metadata")
  ipAddress   String?   @db.VarChar(50) @map("ip_address")
  userAgent   String?   @db.Text @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════
// USER
// ═══════════════════════════════
model User {
  id                    String            @id @default(cuid()) @map("id")
  tenantId              String?           @map("tenant_id")
  email                 String            @db.VarChar(200) @map("email")
  phone                 String?           @db.VarChar(20) @map("phone")
  name                  String            @db.VarChar(100) @map("name")
  role                  UserRole          @default(AGENT) @map("role")
  gender                Gender            @default(MALE) @map("gender")
  passwordHash          String            @db.Text @map("password_hash")
  avatarUrl             String?           @db.Text @map("avatar_url")
  isActive              Boolean           @default(true) @map("is_active")
  isSuperAdmin          Boolean           @default(false) @map("is_super_admin")
  hasFullDataAccess     Boolean           @default(false) @map("has_full_data_access")
  lastLoginAt           DateTime?         @map("last_login_at")
  birthday              DateTime?         @map("birthday")
  anniversary           DateTime?         @map("anniversary")
  language              SupportedLanguage @default(en) @map("language")
  commissionRate        Decimal?          @default(0) @db.Decimal(5, 2) @map("commission_rate")
  commissionType        CommissionType    @default(PERCENT) @map("commission_type")
  fixedCommissionAmount Decimal?          @db.Decimal(12, 2) @map("fixed_commission_amount")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  tenant                 Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedLeads          Lead[]                   @relation("AssignedToUser")
  createdLeads           Lead[]                   @relation("CreatedByUser")
  activities             Activity[]
  followUps              FollowUp[]
  sentMessages           Message[]                @relation("MessageSender")
  commissionTransactions CommissionTransaction[] @relation("AgentCommission")
  createdCommissions     CommissionTransaction[] @relation("CommissionCreatedBy")
  assignedProperties     Property[]               @relation("AssignedProperty")
  blogPosts              BlogPost[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([deletedAt])
  @@map("users")
}

// ═══════════════════════════════
// LEAD
// ═══════════════════════════════
model Lead {
  id                  String             @id @default(cuid()) @map("id")
  tenantId            String             @map("tenant_id")
  assignedToId        String?            @map("assigned_to_id")
  createdById         String             @map("created_by_id")
  preferredPropertyId String?            @map("preferred_property_id")
  closedPropertyId    String?            @map("closed_property_id")
  name                String             @db.VarChar(100) @map("name")
  phone               String             @db.VarChar(20) @map("phone")
  email               String?            @db.VarChar(200) @map("email")
  alternatePhone      String?            @db.VarChar(20) @map("alternate_phone")
  budgetMin           Decimal?           @db.Decimal(12, 2) @map("budget_min")
  budgetMax           Decimal?           @db.Decimal(12, 2) @map("budget_max")
  message             String?            @db.Text @map("message")
  status              LeadStatus         @default(HOT) @map("status")
  source              LeadSource         @default(OTHER) @map("source")
  customFields        Json?              @map("custom_fields")
  nextFollowUpAt      DateTime?          @map("next_follow_up_at")
  lastContactedAt     DateTime?          @map("last_contacted_at")
  convertedAt         DateTime?          @map("converted_at")
  closedAt            DateTime?          @map("closed_at")
  lostReason          String?            @db.VarChar(255) @map("lost_reason")
  preferredLanguage   SupportedLanguage? @map("preferred_language")
  finalSaleValue      Decimal?           @db.Decimal(12, 2) @map("final_sale_value")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo               User?                     @relation("AssignedToUser", fields: [assignedToId], references: [id])
  createdBy                User                      @relation("CreatedByUser", fields: [createdById], references: [id])
  preferredProperty        Property?                 @relation("PreferredProperty", fields: [preferredPropertyId], references: [id])
  closedProperty           Property?                 @relation("ClosedProperty", fields: [closedPropertyId], references: [id])
  messages                 Message[]
  activities               Activity[]
  followUps                FollowUp[]
  commissionTransactions CommissionTransaction[]

  @@index([tenantId, status, nextFollowUpAt])
  @@index([tenantId, assignedToId, status])
  @@index([tenantId, phone])
  @@index([tenantId, createdAt])
  @@index([deletedAt])
  @@map("leads")
}

// ═══════════════════════════════
// PROPERTY
// ═══════════════════════════════
model Property {
  id          String         @id @default(cuid()) @map("id")
  tenantId    String         @map("tenant_id")
  assignedToId String?       @map("assigned_to_id")
  title       String         @db.VarChar(200) @map("title")
  description String?        @db.Text @map("description")
  type        PropertyType   @map("type")
  status      PropertyStatus @default(AVAILABLE) @map("status")
  price       Decimal?       @db.Decimal(12, 2) @map("price")
  areaSqFt    Int?           @map("area_sq_ft")
  bhk         Int?           @map("bhk")
  floor       String?        @db.VarChar(50) @map("floor")
  location    String         @db.VarChar(255) @map("location")
  latitude    Float?         @map("latitude")
  longitude   Float?         @map("longitude")
  images      String[]       @map("images")
  brochures   String[]       @map("brochures")
  features    Json?          @map("features")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo    User?          @relation("AssignedProperty", fields: [assignedToId], references: [id])
  preferredBy   Lead[]         @relation("PreferredProperty")
  closedBy      Lead[]         @relation("ClosedProperty")
  brochureLinks BrochureLink[]

  @@index([tenantId, status, type])
  @@index([tenantId, price])
  @@index([tenantId, assignedToId])
  @@index([deletedAt])
  @@map("properties")
}

// ═══════════════════════════════
// MESSAGE
// ═══════════════════════════════
model Message {
  id          String    @id @default(cuid()) @map("id")
  tenantId    String    @map("tenant_id")
  leadId      String    @map("lead_id")
  senderId    String?   @map("sender_id")
  content     String    @db.Text @map("content")
  isFromLead  Boolean   @default(true) @map("is_from_lead")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender User?  @relation("MessageSender", fields: [senderId], references: [id])

  @@index([tenantId, leadId, createdAt])
  @@map("messages")
}

// ═══════════════════════════════
// ACTIVITY
// ═══════════════════════════════
model Activity {
  id        String       @id @default(cuid()) @map("id")
  tenantId  String       @map("tenant_id")
  leadId    String       @map("lead_id")
  userId    String       @map("user_id")
  type      ActivityType @map("type")
  notes     String?      @db.Text @map("notes")
  createdAt DateTime     @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, leadId, createdAt])
  @@map("activities")
}

// ═══════════════════════════════
// FOLLOW-UP
// ═══════════════════════════════
model FollowUp {
  id           String    @id @default(cuid()) @map("id")
  tenantId     String    @map("tenant_id")
  leadId       String    @map("lead_id")
  assignedToId String    @map("assigned_to_id")
  message      String?   @db.Text @map("message")
  dueAt        DateTime  @map("due_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead       Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User   @relation(fields: [assignedToId], references: [id])

  @@index([tenantId, dueAt, completedAt])
  @@index([tenantId, assignedToId, completedAt])
  @@map("follow_ups")
}

// ═══════════════════════════════
// COMMISSION TRANSACTION
// ═══════════════════════════════
model CommissionTransaction {
  id               String           @id @default(cuid()) @map("id")
  tenantId         String           @map("tenant_id")
  leadId           String           @map("lead_id")
  agentId          String           @map("agent_id")
  createdById      String           @map("created_by_id")
  amount           Decimal          @db.Decimal(12, 2) @map("amount")
  currency         String           @default("INR") @db.VarChar(3) @map("currency")
  status           CommissionStatus @default(PENDING) @map("status")
  calculatedAt     DateTime         @default(now()) @map("calculated_at")
  paidAt           DateTime?        @map("paid_at")
  paymentReference String?          @db.VarChar(255) @map("payment_reference")
  notes            String?          @db.Text @map("notes")
  voidedAt         DateTime?        @map("voided_at")
  voidReason       String?          @db.VarChar(255) @map("void_reason")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead      Lead   @relation(fields: [leadId], references: [id])
  agent     User   @relation("AgentCommission", fields: [agentId], references: [id])
  createdBy User   @relation("CommissionCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, agentId, status])
  @@index([tenantId, leadId])
  @@index([tenantId, calculatedAt])
  @@map("commission_transactions")
}

// ═══════════════════════════════
// BROCHURE LINK
// ═══════════════════════════════
model BrochureLink {
  id          String    @id @default(cuid()) @map("id")
  tenantId    String    @map("tenant_id")
  propertyId  String    @map("property_id")
  token       String    @unique @db.VarChar(64) @map("token")
  expiresAt   DateTime  @map("expires_at")
  openedCount Int       @default(0) @map("opened_count")
  openedAt    DateTime? @map("opened_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])

  @@index([token])
  @@index([expiresAt])
  @@map("brochure_links")
}

// ═══════════════════════════════
// BLOG POST
// ═══════════════════════════════
model BlogPost {
  id              String    @id @default(cuid()) @map("id")
  tenantId        String    @map("tenant_id")
  authorId        String    @map("author_id")
  title           String    @db.VarChar(255) @map("title")
  slug            String    @map("slug")
  excerpt         String?   @db.VarChar(500) @map("excerpt")
  content         String    @db.Text @map("content")
  coverImage      String?   @db.Text @map("cover_image")
  metaTitle       String?   @db.VarChar(70) @map("meta_title")
  metaDescription String?   @db.VarChar(160) @map("meta_description")
  tags            String[]  @map("tags")
  isPublished     Boolean   @default(false) @map("is_published")
  publishedAt     DateTime? @map("published_at")
  viewCount       Int       @default(0) @map("view_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId, isPublished, publishedAt])
  @@map("blog_posts")
}
